# Environment variable template – copy to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=surveyapp
DB_USERNAME=surveyapp_user
DB_PASSWORD=change_me

# pgAdmin
PGADMIN_EMAIL=admin@survey-app.com
PGADMIN_PASSWORD=change_me
PGADMIN_PORT=5050

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000
