# Environment variable template – copy to .env and fill in your values
# Usage: cp .env.example .env  and then edit the values

# Database password for PostgreSQL (used by docker-compose)
DB_PASSWORD=change_me

# JWT secret for signing tokens – use a long, random, Base64-encoded string
# Generate one with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_base64_string
